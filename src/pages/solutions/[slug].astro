---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('solutions');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base
  title={entry.data.title}
  description={entry.data.summary}
  isDraft={entry.data.status === 'draft'}
  breadcrumbs={[
    { label: 'Solutions', href: '/solutions/' },
    { label: entry.data.title },
  ]}
>
  <article class="max-w-prose" data-pagefind-body>
    <header class="mb-6">
      <h1 class="text-2xl font-bold">{entry.data.title}</h1>
      {entry.data.proposedBy && (
        <p class="text-sm text-sc-muted dark:text-sc-muted-dark mt-1">Proposed by: {entry.data.proposedBy}</p>
      )}
    </header>
    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</Base>
