---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allSolutions = await getCollection('solutions');
const sorted = allSolutions.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Base title="Solutions" description="Stress-testing proposed reforms with tradeoff analysis." breadcrumbs={[{ label: 'Solutions' }]}>
  <article class="max-w-prose">
    <h1 class="text-2xl font-bold mb-2">Solutions</h1>
    <p class="text-sc-muted dark:text-sc-muted-dark mb-6">
      Not prescriptions or manifestos — take other people's proposed reforms and stress-test
      them honestly. What would each actually mean? Who benefits, who loses? What are the
      second-order effects? Why hasn't it happened despite being obviously sensible?
    </p>

    <ul class="space-y-4">
      {sorted.map(sol => (
        <li>
          <a href={`/solutions/${sol.id}/`} class="group block">
            <span class="font-medium group-hover:text-sc-accent dark:group-hover:text-sc-accent-dark">{sol.data.title}</span>
            {sol.data.status === 'draft' && (
              <span class="text-xs text-amber-600 dark:text-amber-400 ml-2">DRAFT</span>
            )}
            {sol.data.status === 'stub' && (
              <span class="text-xs text-sc-muted dark:text-sc-muted-dark ml-2">STUB</span>
            )}
            <p class="text-sm text-sc-muted dark:text-sc-muted-dark mt-0.5">{sol.data.summary}</p>
          </a>
        </li>
      ))}
    </ul>
  </article>
</Base>
