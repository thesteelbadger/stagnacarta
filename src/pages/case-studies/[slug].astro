---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base
  title={entry.data.title}
  description={entry.data.summary}
  isDraft={entry.data.status === 'draft'}
  breadcrumbs={[
    { label: 'Case Studies', href: '/case-studies/' },
    { label: entry.data.title },
  ]}
>
  <article class="max-w-prose" data-pagefind-body>
    <header class="mb-6">
      <div class="flex items-center gap-2 mb-2">
        <span class:list={[
          'px-1.5 py-0.5 rounded text-xs font-medium',
          entry.data.type === 'failure'
            ? 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-300'
            : 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300',
        ]}>
          {entry.data.type}
        </span>
      </div>

      <h1 class="text-2xl font-bold">{entry.data.title}</h1>
      {entry.data.subtitle && (
        <p class="text-lg text-sc-muted dark:text-sc-muted-dark mt-1">{entry.data.subtitle}</p>
      )}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>

    <footer class="mt-10 pt-6 border-t border-sc-border dark:border-sc-border-dark text-sm">
      {entry.data.mechanisms.length > 0 && (
        <div class="mb-3">
          <span class="text-sc-muted dark:text-sc-muted-dark">Mechanisms: </span>
          <span class="flex flex-wrap gap-1.5 mt-1">
            {entry.data.mechanisms.map(m => (
              <a href={`/mechanisms/${m}/`} class="tag">{m.replace(/-/g, ' ')}</a>
            ))}
          </span>
        </div>
      )}

      {entry.data.organs.length > 0 && (
        <div class="mb-3">
          <span class="text-sc-muted dark:text-sc-muted-dark">Organs: </span>
          <span class="flex flex-wrap gap-1.5 mt-1">
            {entry.data.organs.map(o => (
              <a href={`/organs/${o}/`} class="tag">{o.replace(/-/g, ' ')}</a>
            ))}
          </span>
        </div>
      )}

      {entry.data.sources.length > 0 && (
        <div class="mb-3">
          <span class="text-sc-muted dark:text-sc-muted-dark">Sources:</span>
          <ul class="mt-1 space-y-0.5 text-sc-muted dark:text-sc-muted-dark">
            {entry.data.sources.map(s => <li>{s}</li>)}
          </ul>
        </div>
      )}

      {entry.data.lastUpdated && (
        <p class="mt-4 text-sc-muted dark:text-sc-muted-dark">
          Last updated: {entry.data.lastUpdated.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </p>
      )}
    </footer>
  </article>
</Base>
