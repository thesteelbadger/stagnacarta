---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { getConnectedIds } from '../../lib/connections';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const nodeId = `case-studies/${entry.id}`;
const mechanismIds = getConnectedIds(nodeId, 'mechanisms');
const organIds = getConnectedIds(nodeId, 'organs');

const allMechanisms = await getCollection('mechanisms');
const allOrgans = await getCollection('organs');
const mechMap = Object.fromEntries(allMechanisms.map(m => [m.id, m.data.title]));
const organMap = Object.fromEntries(allOrgans.map(o => [o.id, o.data.title]));
---

<Base
  title={entry.data.title}
  description={entry.data.summary}
  isDraft={entry.data.status === 'draft'}
  breadcrumbs={[
    { label: 'Case Studies', href: '/case-studies/' },
    { label: entry.data.title },
  ]}
>
  <article class="max-w-prose" data-pagefind-body>
    <header class="mb-8">
      <h1 class="text-2xl font-bold mb-1">{entry.data.title}</h1>
      {entry.data.subtitle && (
        <p class="text-sc-muted dark:text-sc-muted-dark mb-4">{entry.data.subtitle}</p>
      )}

      {mechanismIds.length > 0 && (
        <div class="mb-2">
          <span class="text-sc-muted dark:text-sc-muted-dark text-sm">Mechanisms: </span>
          <span class="inline-flex flex-wrap gap-1.5">
            {mechanismIds.map(m => (
              <a href={`/mechanisms/${m}/`} class="tag">{mechMap[m] || m}</a>
            ))}
          </span>
        </div>
      )}

      {organIds.length > 0 && (
        <div class="mb-2">
          <span class="text-sc-muted dark:text-sc-muted-dark text-sm">Organs: </span>
          <span class="inline-flex flex-wrap gap-1.5">
            {organIds.map(o => (
              <a href={`/organs/${o}/`} class="tag">{organMap[o] || o}</a>
            ))}
          </span>
        </div>
      )}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>

    {entry.data.sources.length > 0 && (
      <footer class="mt-10 pt-6 border-t border-sc-border dark:border-sc-border-dark text-sm">
        <span class="text-sc-muted dark:text-sc-muted-dark">Sources:</span>
        <ul class="mt-1 space-y-0.5 text-sc-muted dark:text-sc-muted-dark">
          {entry.data.sources.map(s => <li>{s}</li>)}
        </ul>
      </footer>
    )}
  </article>
</Base>
