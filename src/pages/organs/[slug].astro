---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('organs');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allCaseStudies = await getCollection('case-studies');
const allMechanisms = await getCollection('mechanisms');
const csTitles = Object.fromEntries(allCaseStudies.map(c => [c.id, c.data.title]));
const mechTitles = Object.fromEntries(allMechanisms.map(m => [m.id, m.data.title]));
---

<Base
  title={entry.data.title}
  description={`${entry.data.metric} — ${entry.data.divergence}`}
  isDraft={entry.data.status === 'draft'}
  breadcrumbs={[
    { label: 'Organs', href: '/organs/' },
    { label: entry.data.title },
  ]}
>
  <article class="max-w-prose" data-pagefind-body>
    <header class="mb-8">
      <h1 class="text-2xl font-bold mb-4">{entry.data.title}</h1>

      {entry.data.caseStudies.length > 0 && (
        <div class="mb-2">
          <span class="text-sc-muted dark:text-sc-muted-dark text-sm">Case Studies: </span>
          <span class="inline-flex flex-wrap gap-1.5">
            {entry.data.caseStudies.map(cs => (
              <a href={`/case-studies/${cs}/`} class="tag">{csTitles[cs] || cs}</a>
            ))}
          </span>
        </div>
      )}

      {entry.data.mechanisms.length > 0 && (
        <div class="mb-2">
          <span class="text-sc-muted dark:text-sc-muted-dark text-sm">Mechanisms: </span>
          <span class="inline-flex flex-wrap gap-1.5">
            {entry.data.mechanisms.map(m => (
              <a href={`/mechanisms/${m}/`} class="tag">{mechTitles[m] || m}</a>
            ))}
          </span>
        </div>
      )}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</Base>
