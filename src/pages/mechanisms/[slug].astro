---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('mechanisms');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allCaseStudies = await getCollection('case-studies');
const allOrgans = await getCollection('organs');
const csTitles = Object.fromEntries(allCaseStudies.map(c => [c.id, c.data.title]));
const organTitles = Object.fromEntries(allOrgans.map(o => [o.id, o.data.title]));

// Find organs that exhibit this mechanism
const relatedOrgans = allOrgans.filter(o => o.data.mechanisms.includes(entry.id));
---

<Base
  title={entry.data.title}
  description={entry.data.definition}
  isDraft={entry.data.status === 'draft'}
  breadcrumbs={[
    { label: 'Mechanisms', href: '/mechanisms/' },
    { label: entry.data.title },
  ]}
>
  <article class="max-w-prose" data-pagefind-body>
    <header class="mb-8">
      {entry.data.status === 'candidate' && (
        <span class="text-xs text-amber-600 dark:text-amber-400 mb-2 inline-block">CANDIDATE MECHANISM</span>
      )}
      <h1 class="text-2xl font-bold mb-2">{entry.data.title}</h1>
      <p class="text-sc-muted dark:text-sc-muted-dark mb-4">{entry.data.definition}</p>

      {entry.data.caseStudies.length > 0 && (
        <div class="mb-2">
          <span class="text-sc-muted dark:text-sc-muted-dark text-sm">Case Studies: </span>
          <span class="inline-flex flex-wrap gap-1.5">
            {entry.data.caseStudies.map(cs => (
              <a href={`/case-studies/${cs}/`} class="tag">{csTitles[cs] || cs}</a>
            ))}
          </span>
        </div>
      )}

      {relatedOrgans.length > 0 && (
        <div class="mb-2">
          <span class="text-sc-muted dark:text-sc-muted-dark text-sm">Organs: </span>
          <span class="inline-flex flex-wrap gap-1.5">
            {relatedOrgans.map(o => (
              <a href={`/organs/${o.id}/`} class="tag">{o.data.title}</a>
            ))}
          </span>
        </div>
      )}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</Base>
